# Copy this file to .env and fill in your values
# The docker-compose.yml reads from this file automatically

PORT=5000
NODE_ENV=production
RENDER_EXTERNAL_URL=https://your-backend.onrender.com

# Comma-separated list of allowed frontend origins
# For local Docker dev: http://localhost:5173 is set automatically by docker-compose
# For production (Render): set this to your deployed frontend URL
ALLOWED_ORIGINS=https://your-frontend.onrender.com

MONGO_URI=
JWT_SECRET=

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Email — Mailjet + Resend
FROM_EMAIL=
MAILJET_API_KEY=
MAILJET_SECRET_KEY=
RESEND_API_KEY=

# AI Chatbot
GROQ_API_KEY=

# Redis (Upstash)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
