# Copy this file to .env and fill in your values
# The docker-compose.yml reads from this file automatically

PORT=5000
NODE_ENV=production
RENDER_EXTERNAL_URL=https://your-backend.onrender.com

# Comma-separated list of allowed frontend origins
# For production (Render or EC2): set this to your deployed domain or IPs
ALLOWED_ORIGINS=https://your-domain.com,http://localhost:5173

# Frontend API URL configuration
# Usually point this back to your domain (e.g., https://your-domain.com) 
# or your EC2 IP (e.g. http://XX.XX.XX.XX:5000)
VITE_API_URL_PROD=https://your-domain.com

MONGO_URI=
JWT_SECRET=

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Email — Mailjet + Resend
FROM_EMAIL=
MAILJET_API_KEY=
MAILJET_SECRET_KEY=
RESEND_API_KEY=

# AI Chatbot
GROQ_API_KEY=

# Redis (Upstash)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
